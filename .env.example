# Example environment variables (do NOT commit real keys)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=pk.xxx
SUPABASE_SERVICE_ROLE_KEY=sk.xxx   # server-side only, never expose to frontend

STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx     # server-side only
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PRO_ID=price_XXXXXX  # Stripe price ID for the Pro plan

# BASE_URL is used to build success/cancel URLs when testing locally or in deployment
BASE_URL=http://localhost:3000
