# Local environment variables example for development
# Copy this to .env.local (DO NOT commit .env.local to git)

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...          # public anon key (safe for client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # SERVICE ROLE KEY (VERY SENSITIVE — server only)

# Stripe (test keys for local development)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_PRO_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App
BASE_URL=http://localhost:5000
DISABLE_STRIPE_WEBHOOK_VERIFY=1   # dev only: do NOT enable in production

# IMPORTANT:
# - Never commit the service role key or Stripe secret keys to source control.
# - Use your hosting provider's environment variable settings (e.g., Vercel) for production.
